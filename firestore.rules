rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && (
        request.auth.token.email == "maninhoneeto@gmail.com" ||
        request.auth.token.email.matches(".*maninhoneeto.*") ||
        (request.auth.token.keys().contains("name") && request.auth.token.name.matches(".*maninhoneeto.*"))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Customers
    match /customers/{customerId} {
      allow read: if isOwner();
      allow create: if isOwner() && isValidCustomer(incoming());
      allow update: if isOwner() && isValidCustomer(incoming()) 
                     && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner();

      function isValidCustomer(data) {
        return data.keys().hasAll(['name', 'phone', 'createdAt'])
               && data.keys().size() <= 6
               && data.name is string && data.name.size() > 0 && data.name.size() <= 200
               && data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 20
               && (data.get('email', '') == '' || (data.email is string && data.email.size() <= 200))
               && (data.get('address', '') == '' || (data.address is string && data.address.size() <= 500))
               && data.createdAt is timestamp;
      }
    }

    // 2. Installations
    match /installations/{installationId} {
      allow read: if isOwner();
      allow create: if isOwner() && isValidInstallation(incoming());
      allow update: if isOwner() && isValidInstallation(incoming())
                     && incoming().customerId == existing().customerId
                     && incoming().createdAt == existing().createdAt;
      allow delete: if isOwner();

      function isValidInstallation(data) {
        return data.keys().hasAll(['customerId', 'type', 'status', 'createdAt'])
               && data.keys().size() <= 10
               && isValidId(data.customerId)
               && data.type in ['Câmera', 'Alarme', 'Cerca Elétrica', 'Interfone', 'Outro']
               && data.status in ['Em andamento', 'Concluído', 'Manutenção']
               && data.createdAt is timestamp
               && (data.get('description', '') == '' || (data.description is string && data.description.size() <= 1000))
               && (data.get('photosBefore', []) is list && data.photosBefore.size() <= 10)
               && (data.get('photosAfter', []) is list && data.photosAfter.size() <= 10);
      }
    }

    // 3. Maintenance
    match /maintenance/{reminderId} {
      allow read: if isOwner();
      allow create: if isOwner() && isValidMaintenance(incoming());
      allow update: if isOwner() && isValidMaintenance(incoming())
                     && incoming().customerId == existing().customerId;
      allow delete: if isOwner();

      function isValidMaintenance(data) {
        return data.keys().hasAll(['customerId', 'dueDate', 'taskType', 'completed'])
               && data.keys().size() <= 6
               && isValidId(data.customerId)
               && data.taskType is string && data.taskType.size() <= 200
               && data.dueDate is timestamp
               && data.completed is bool;
      }
    }

    // 4. Visits
    match /visits/{visitId} {
      allow create: if isValidVisit(incoming());
      allow read: if isOwner();
      
      function isValidVisit(data) {
        return data.keys().hasAll(['timestamp', 'userAgent', 'page'])
               && data.keys().size() <= 25
               && data.timestamp == request.time
               && data.userAgent is string && data.userAgent.size() <= 1000
               && data.page is string && data.page.size() <= 200
               && (data.get('device', '') == '' || (data.device is string && data.device.size() <= 100))
               && (data.get('screen', '') == '' || (data.screen is string && data.screen.size() <= 100))
               && (data.get('language', '') == '' || (data.language is string && data.language.size() <= 100))
               && (data.get('referrer', '') == '' || (data.referrer is string && data.referrer.size() <= 500))
               && (data.get('source', '') == '' || (data.source is string && data.source.size() <= 200))
               && (data.get('utm_source', null) == null || (data.utm_source is string && data.utm_source.size() <= 200))
               && (data.get('utm_medium', null) == null || (data.utm_medium is string && data.utm_medium.size() <= 200))
               && (data.get('utm_campaign', null) == null || (data.utm_campaign is string && data.utm_campaign.size() <= 200))
               && (data.get('userEmail', null) == null || (data.userEmail is string && data.userEmail.size() <= 200))
               && (data.get('userName', null) == null || (data.userName is string && data.userName.size() <= 200))
               && (data.get('userProvider', null) == null || (data.userProvider is string && data.userProvider.size() <= 100));
      }
    }

    // 5. Conversions
    match /conversions/{conversionId} {
      allow create: if isValidConversion(incoming());
      allow read: if isOwner();

      function isValidConversion(data) {
        return data.keys().hasAll(['timestamp', 'page', 'type'])
               && data.keys().size() <= 10
               && data.timestamp != null
               && data.page is string && data.page.size() <= 200
               && data.type is string && data.type.size() <= 200;
      }
    }
  }
}
